---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../consts';
import { t } from '../i18n';

interface Props {
  title?: string;
  description?: string;
  ogType?: 'website' | 'article';
  /** Document language; drives full-page direction. */
  lang?: 'en' | 'fa';
}

const { title, description = SITE.description, ogType = 'website', lang = 'en' } = Astro.props;
const pageTitle = title ? `${title} · ${SITE.title}` : SITE.title;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const hasSidebar = Astro.slots.has('sidebar');
const dir = lang === 'fa' ? 'rtl' : 'ltr';
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={`${SITE.title} · everything`} href="/feed.xml" />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={SITE.author} />
    {SITE.googleSiteVerification && (
      <meta name="google-site-verification" content={SITE.googleSiteVerification} />
    )}
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE.title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />

    <!-- fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Onest:wght@300..600&family=Geist+Mono:wght@400;500&family=Vazirmatn:wght@300..700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a class="skip" href="#main">{t(lang, 'skip')}</a>
    <div class={hasSidebar ? 'shell shell-wide' : 'shell'}>
      <Header lang={lang} />
      {
        hasSidebar ? (
          <div class="layout">
            <main id="main">
              <slot />
            </main>
            <slot name="sidebar" />
          </div>
        ) : (
          <main id="main">
            <slot />
          </main>
        )
      }
      <Footer lang={lang} />
    </div>
  </body>
</html>
