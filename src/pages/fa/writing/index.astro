---
import Base from '../../../layouts/Base.astro';
import Stream from '../../../components/Stream.astro';
import Sidebar from '../../../components/Sidebar.astro';
import { getStreamItems } from '../../../lib/stream';

const items = (await getStreamItems()).filter((i) => i.lang === 'fa' && i.type === 'entry');
---

<Base lang="fa" title="نوشته‌ها" description="نوشته‌های بلند سینا سعیدی.">
  <section class="intro">
    <h1>نوشته‌ها</h1>
    <p>نوشته‌های بلند دربارهٔ سیستم‌ها، مهندسی و گاهی فلسفه.</p>
  </section>

  <Stream items={items} lang="fa" />

  <Sidebar slot="sidebar" lang="fa" contentLang="fa" />
</Base>
