---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const projects = (await getCollection('projects')).sort((a, b) => {
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  if (a.data.order !== b.data.order) return a.data.order - b.data.order;
  return (b.data.year ?? 0) - (a.data.year ?? 0);
});

const STATUS_LABEL = { active: 'فعال', archived: 'بایگانی', wip: 'در حال کار' } as const;
const faYear = (y: number) => new Intl.NumberFormat('fa-IR', { useGrouping: false }).format(y);
---

<Base lang="fa" title="پروژه‌ها" description="چیزهایی که سینا سعیدی ساخته است.">
  <section class="page-head">
    <h1>پروژه‌ها</h1>
    <p>چند چیزی که ساخته‌ام و نگه‌داری می‌کنم — بیشتر متن‌باز، بیشتر در حال‌وهوای سیستم‌ها.</p>
  </section>

  <div class="projects">
    {
      projects.map((p) => {
        const href = p.data.link ?? p.data.repo;
        const Tag = href ? 'a' : 'div';
        return (
          <Tag class="project" href={href} {...(href ? { target: '_blank', rel: 'noopener' } : {})}>
            <div class="ptop">
              <h3>{p.data.titleFa ?? p.data.title}</h3>
              {p.data.status && <span class="pstatus">{STATUS_LABEL[p.data.status]}</span>}
              {p.data.year && <span class="pyear">{faYear(p.data.year)}</span>}
            </div>
            <p class="pdesc">{p.data.descriptionFa ?? p.data.description}</p>
            <div class="pmeta">
              {p.data.tech.length > 0 && <span class="ptech">{p.data.tech.join(' · ')}</span>}
              <span class="plinks">
                {p.data.repo && <span>کد ↗</span>}
                {p.data.link && <span>دمو ↗</span>}
              </span>
            </div>
          </Tag>
        );
      })
    }
    {projects.length === 0 && <p class="empty">هنوز پروژه‌ای نیست.</p>}
  </div>
</Base>
