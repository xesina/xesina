---
import Base from '../../../layouts/Base.astro';
import Stream from '../../../components/Stream.astro';
import Sidebar from '../../../components/Sidebar.astro';
import { getArchive, getItemsByMonth } from '../../../lib/taxonomy';

export async function getStaticPaths() {
  const years = await getArchive('en');
  return years.flatMap((y) =>
    y.months.map((m) => ({
      params: { year: String(y.year), month: m.slug },
      props: { year: y.year, monthIndex: m.monthIndex, label: m.label, total: m.counts.total },
    })),
  );
}

const { year, monthIndex, label, total } = Astro.props;
const items = await getItemsByMonth(year, monthIndex, 'en');
---

<Base title={`Archive ${label}`} description={`Everything from ${label} on sinasaeidi.com.`}>
  <section class="page-head">
    <h1>{label}</h1>
    <p>
      {total} {total === 1 ? 'item' : 'items'} ·
      <a href={`/${year}/`}>{year}</a> ·
      <a href="/archive/">all years</a>
    </p>
  </section>

  <Stream items={items} />

  <Sidebar slot="sidebar" contentLang="en" />
</Base>
